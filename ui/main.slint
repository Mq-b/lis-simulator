import { Button, LineEdit, ComboBox, VerticalBox, HorizontalBox,
         ScrollView, TextEdit, CheckBox, GroupBox, StandardTableView,
         Spinner, Switch, ListView, Palette } from "std-widgets.slint";

// ═══════════════════════════════════════════════════════════════
// 颜色主题
// ═══════════════════════════════════════════════════════════════

global Theme {
    in property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;

    // 背景色
    out property <color> bg-primary: is-dark ? #1a1d23 : #f8f9fa;
    out property <color> bg-secondary: is-dark ? #22262e : #ffffff;
    out property <color> bg-tertiary: is-dark ? #2a2f38 : #f1f3f5;
    out property <color> bg-hover: is-dark ? #323842 : #e9ecef;
    out property <color> bg-header: is-dark ? #2d333b : #e2e6ea;
    out property <color> bg-tx: is-dark ? #1a2332 : #e8f4fd;

    // 强调色
    out property <color> accent-blue: is-dark ? #58a6ff : #0078d4;
    out property <color> accent-green: is-dark ? #3fb950 : #107c10;
    out property <color> accent-red: is-dark ? #f85149 : #d13438;
    out property <color> accent-orange: is-dark ? #d29922 : #c19c00;
    out property <color> accent-purple: is-dark ? #bc8cff : #7b2fbe;

    // 记录类型标签色
    out property <color> tag-h: is-dark ? #f0883e : #c76b1c;
    out property <color> tag-p: is-dark ? #3fb950 : #107c10;
    out property <color> tag-r: is-dark ? #58a6ff : #0078d4;
    out property <color> tag-l: is-dark ? #f85149 : #d13438;
    out property <color> tag-q: is-dark ? #bc8cff : #7b2fbe;

    // 文字色
    out property <color> text-primary: is-dark ? #e6edf3 : #1a1a1a;
    out property <color> text-secondary: is-dark ? #8b949e : #605e5c;
    out property <color> text-muted: is-dark ? #484f58 : #a19f9d;
    out property <color> text-label: is-dark ? #c9d1d9 : #3b3a39;

    // 边框
    out property <color> border-default: is-dark ? #30363d : #d2d0ce;
    out property <color> border-active: is-dark ? #58a6ff : #0078d4;
}

// ═══════════════════════════════════════════════════════════════
// 数据结构
// ═══════════════════════════════════════════════════════════════

export struct LogEntry {
    timestamp: string,
    direction: string,
    ctrl-type: string,
    raw-data: string,
    hex-data: string,
}

export struct ResultRow {
    item-code: string,
    value: string,
    unit: string,
    flag: string,
    ref-range: string,
    test-time: string,
}

export struct ParsedMessage {
    msg-index: string,
    h-sender: string,
    h-msg-type: string,
    h-version: string,
    h-time: string,
    p-patient-id: string,
    p-name: string,
    p-age: string,
    p-sex: string,
    p-visit-type: string,
    p-bed: string,
    p-doctor: string,
    p-department: string,
    has-patient: bool,
    l-terminator: string,
}

// ═══════════════════════════════════════════════════════════════
// 通用子组件：标签徽章
// ═══════════════════════════════════════════════════════════════

component TagBadge inherits Rectangle {
    in property <string> label;
    in property <color> tag-color;
    width: tag-label.preferred-width + 12px;
    height: 20px;
    border-radius: 3px;
    background: tag-color.transparentize(80%);
    border-width: 1px;
    border-color: tag-color.transparentize(60%);
    tag-label := Text {
        text: root.label;
        font-size: 10px;
        font-weight: 700;
        color: tag-color;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ═══════════════════════════════════════════════════════════════
// 通用子组件：面板标题栏
// ═══════════════════════════════════════════════════════════════

component PanelHeader inherits Rectangle {
    in property <string> title;
    in property <color> accent;
    in property <string> icon;
    height: 32px;
    background: Theme.bg-header;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        Rectangle {
            width: 3px;
            height: 16px;
            border-radius: 1px;
            background: root.accent;
        }
        Text {
            text: root.icon + " " + root.title;
            font-size: 12px;
            font-weight: 600;
            color: Theme.text-primary;
            vertical-alignment: center;
        }
    }
}

// ═══════════════════════════════════════════════════════════════
// 子组件：串口配置面板
// ═══════════════════════════════════════════════════════════════

component SerialConfigPanel inherits Rectangle {
    in property <[string]> port-list: [];
    in property <[string]> baud-rate-list: ["1200", "2400", "4800", "9600", "19200", "38400", "57600", "115200"];
    in property <[string]> data-bits-list: ["5", "6", "7", "8"];
    in property <[string]> parity-list: ["None", "Odd", "Even"];
    in property <[string]> stop-bits-list: ["1", "1.5", "2"];
    in property <[string]> flow-control-list: ["None", "Hardware", "Software"];
    in property <bool> is-connected: false;

    in-out property <int> selected-port-idx: 0;
    in-out property <int> selected-baud-idx: 3;
    in-out property <int> selected-databits-idx: 3;
    in-out property <int> selected-parity-idx: 0;
    in-out property <int> selected-stopbits-idx: 0;
    in-out property <int> selected-flowctrl-idx: 0;
    in-out property <bool> is-bidirectional: false;

    callback refresh-ports();
    callback connect-clicked();
    callback disconnect-clicked();

    border-radius: 6px;
    background: Theme.bg-secondary;
    border-width: 1px;
    border-color: Theme.border-default;

    VerticalLayout {
        PanelHeader {
            title: "串口配置";
            icon: "";
            accent: Theme.accent-blue;
        }

        HorizontalLayout {
            padding: 10px;
            spacing: 12px;
            alignment: stretch;

            // 左列：串口参数
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "串口号"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
                    ComboBox { model: root.port-list; current-index <=> root.selected-port-idx; max-width: 100px; }
                    Button { text: "刷新"; clicked => { root.refresh-ports(); } }
                    Rectangle { horizontal-stretch: 1; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "波特率"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
                    ComboBox { model: root.baud-rate-list; current-index <=> root.selected-baud-idx; max-width: 90px; }
                    Text { text: "数据位"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
                    ComboBox { model: root.data-bits-list; current-index <=> root.selected-databits-idx; max-width: 50px; }
                    Rectangle { horizontal-stretch: 1; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "校验位"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
                    ComboBox { model: root.parity-list; current-index <=> root.selected-parity-idx; max-width: 70px; }
                    Text { text: "停止位"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
                    ComboBox { model: root.stop-bits-list; current-index <=> root.selected-stopbits-idx; max-width: 50px; }
                    Text { text: "流控"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
                    ComboBox { model: root.flow-control-list; current-index <=> root.selected-flowctrl-idx; max-width: 70px; }
                    Rectangle { horizontal-stretch: 1; }
                }
            }

            // 分隔线
            Rectangle { width: 1px; background: Theme.border-default; }

            // 右列：控制
            VerticalLayout {
                spacing: 8px;
                alignment: center;
                horizontal-stretch: 0;
                min-width: 200px;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Text { text: "模式"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
                    Switch {
                        checked <=> root.is-bidirectional;
                        text: root.is-bidirectional ? "双向" : "单向";
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Button {
                        text: "开始监听";
                        enabled: !root.is-connected;
                        clicked => { root.connect-clicked(); }
                    }
                    Button {
                        text: "停止";
                        enabled: root.is-connected;
                        clicked => { root.disconnect-clicked(); }
                    }
                }

                HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: root.is-connected ? Theme.accent-green : Theme.accent-red;
                    }
                    Text {
                        text: root.is-connected ? "已连接" : "未连接";
                        font-size: 11px;
                        font-weight: 600;
                        color: root.is-connected ? Theme.accent-green : Theme.accent-red;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════
// 子组件：原始数据日志
// ═══════════════════════════════════════════════════════════════

component RawLogPanel inherits Rectangle {
    in property <[LogEntry]> log-entries: [];
    in-out property <bool> auto-scroll: true;
    in-out property <bool> decode-utf8: false;
    callback clear-log();
    callback export-log();

    border-radius: 6px;
    background: Theme.bg-secondary;
    border-width: 1px;
    border-color: Theme.border-default;

    VerticalLayout {
        PanelHeader {
            title: "原始数据日志";
            icon: "";
            accent: Theme.accent-green;
        }

        // 表头
        Rectangle {
            height: 26px;
            background: Theme.bg-header;
            HorizontalLayout {
                spacing: 1px;
                padding-left: 4px;
                padding-right: 4px;
                Rectangle { width: 120px; Text { text: "时间"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                Rectangle { width: 40px; Text { text: "方向"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                Rectangle { width: 56px; Text { text: "类型"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                Rectangle { horizontal-stretch: 1; Text { text: "数据内容"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
            }
        }

        // 数据列表
        ListView {
            vertical-stretch: 1;
            for entry in root.log-entries: Rectangle {
                min-height: 22px;
                background: touch.has-hover ? Theme.bg-hover : (entry.direction == "TX" ? Theme.bg-tx : Theme.bg-tertiary);
                touch := TouchArea {}
                HorizontalLayout {
                    spacing: 1px;
                    padding-left: 4px;
                    padding-right: 4px;
                    padding-top: 3px;
                    padding-bottom: 3px;
                    Rectangle { width: 120px; Text { text: entry.timestamp; font-size: 10px; font-family: "Consolas"; color: Theme.text-muted; vertical-alignment: top; } }
                    Rectangle { width: 40px; Text { text: entry.direction; font-size: 10px; font-weight: 700; color: entry.direction == "TX" ? Theme.accent-blue : Theme.accent-green; vertical-alignment: top; horizontal-alignment: center; } }
                    Rectangle { width: 56px; Text { text: entry.ctrl-type; font-size: 10px; font-family: "Consolas"; color: entry.ctrl-type == "ENQ" ? Theme.accent-orange : entry.ctrl-type == "ACK" ? Theme.accent-green : entry.ctrl-type == "EOT" ? Theme.accent-red : Theme.text-secondary; vertical-alignment: top; horizontal-alignment: center; } }
                    Rectangle { horizontal-stretch: 1; clip: true; Text { text: entry.raw-data; font-size: 10px; font-family: "Consolas"; color: Theme.text-primary; vertical-alignment: top; wrap: char-wrap; width: parent.width; } }
                }
            }
        }

        // 底部工具栏
        Rectangle {
            height: 32px;
            background: Theme.bg-header;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                alignment: end;
                Button { text: "清空"; clicked => { root.clear-log(); } }
                Button { text: "导出"; clicked => { root.export-log(); } }
                CheckBox { text: "自动滚动"; checked <=> root.auto-scroll; }
                CheckBox { text: "UTF-8解码"; checked <=> root.decode-utf8; }
                Rectangle { horizontal-stretch: 1; }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════
// 子组件：解析结果面板
// ═══════════════════════════════════════════════════════════════

component ParsedResultPanel inherits Rectangle {
    in property <[ParsedMessage]> messages: [];
    in property <[[ResultRow]]> result-rows: [];
    callback clear-results();
    callback export-clicked();

    border-radius: 6px;
    background: Theme.bg-secondary;
    border-width: 1px;
    border-color: Theme.border-default;

    VerticalLayout {
        PanelHeader {
            title: "解析结果";
            icon: "";
            accent: Theme.accent-purple;
        }

        ListView {
            vertical-stretch: 1;
            for msg[idx] in root.messages: Rectangle {
                background: Theme.bg-tertiary;
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.border-default;
                height: msg-card.preferred-height;

                msg-card := VerticalLayout {
                    spacing: 0px;
                    padding: 8px;

                    // 消息标题栏
                    Rectangle {
                        height: 24px;
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "消息 " + msg.msg-index;
                                font-size: 12px;
                                font-weight: 700;
                                color: Theme.accent-blue;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: msg.h-time;
                                font-size: 10px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // H 记录 - 橙色标签
                    Rectangle {
                        height: h-content.preferred-height + 10px;
                        background: Theme.tag-h.transparentize(92%);
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.tag-h.transparentize(80%);
                        h-content := VerticalLayout {
                            padding: 6px;
                            spacing: 3px;
                            HorizontalLayout {
                                spacing: 6px;
                                TagBadge { label: "H"; tag-color: Theme.tag-h; }
                                Text { text: "头信息"; font-size: 10px; color: Theme.tag-h; font-weight: 600; vertical-alignment: center; }
                            }
                            Text {
                                text: "发送方: " + msg.h-sender + "   类型: " + msg.h-msg-type + "   协议: " + msg.h-version;
                                font-size: 11px;
                                color: Theme.text-label;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // P 记录 - 绿色标签
                    if msg.has-patient: Rectangle {
                        height: p-content.preferred-height + 10px;
                        background: Theme.tag-p.transparentize(92%);
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.tag-p.transparentize(80%);
                        p-content := VerticalLayout {
                            padding: 6px;
                            spacing: 3px;
                            HorizontalLayout {
                                spacing: 6px;
                                TagBadge { label: "P"; tag-color: Theme.tag-p; }
                                Text { text: "患者信息"; font-size: 10px; color: Theme.tag-p; font-weight: 600; vertical-alignment: center; }
                            }
                            Text {
                                text: "ID: " + msg.p-patient-id + "   姓名: " + msg.p-name + "   年龄: " + msg.p-age + "   性别: " + msg.p-sex;
                                font-size: 11px;
                                color: Theme.text-label;
                                wrap: word-wrap;
                            }
                            Text {
                                text: "就诊: " + msg.p-visit-type + "   医生: " + msg.p-doctor + "   科室: " + msg.p-department;
                                font-size: 11px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // R 记录 - 蓝色标签 + 表格
                    if idx < root.result-rows.length && root.result-rows[idx].length > 0: Rectangle {
                        height: r-content.preferred-height + 10px;
                        background: Theme.tag-r.transparentize(92%);
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.tag-r.transparentize(80%);
                        r-content := VerticalLayout {
                            padding: 6px;
                            spacing: 3px;
                            HorizontalLayout {
                                spacing: 6px;
                                TagBadge { label: "R"; tag-color: Theme.tag-r; }
                                Text { text: "检验结果"; font-size: 10px; color: Theme.tag-r; font-weight: 600; vertical-alignment: center; }
                            }

                            // 表头
                            result-header := Rectangle {
                                height: 22px;
                                background: Theme.bg-header;
                                border-radius: 3px;
                                HorizontalLayout {
                                    spacing: 1px;
                                    Rectangle { width: result-header.width * 20%; Text { text: "项目"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 12%; Text { text: "结果"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 10%; Text { text: "单位"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 10%; Text { text: "标志"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 18%; Text { text: "参考"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 28%; Text { text: "时间"; font-size: 10px; font-weight: 600; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                                }
                            }

                            // 数据行
                            for row in root.result-rows[idx]: Rectangle {
                                height: 22px;
                                background: Theme.bg-tertiary;
                                border-radius: 2px;
                                HorizontalLayout {
                                    spacing: 1px;
                                    Rectangle { width: result-header.width * 20%; Text { text: row.item-code; font-size: 10px; font-family: "Consolas"; color: Theme.text-primary; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 12%; Text { text: row.value; font-size: 10px; font-family: "Consolas"; color: Theme.text-primary; font-weight: 600; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 10%; Text { text: row.unit; font-size: 10px; color: Theme.text-secondary; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 10%; Text {
                                        text: row.flag;
                                        font-size: 10px;
                                        font-weight: 700;
                                        color: row.flag == "偏高" ? Theme.accent-red : row.flag == "偏低" ? Theme.accent-orange : row.flag == "阳性" ? Theme.accent-red : row.flag == "阴性" ? Theme.accent-green : Theme.text-secondary;
                                        vertical-alignment: center;
                                        horizontal-alignment: center;
                                    } }
                                    Rectangle { width: result-header.width * 18%; Text { text: row.ref-range; font-size: 10px; font-family: "Consolas"; color: Theme.text-muted; vertical-alignment: center; horizontal-alignment: center; } }
                                    Rectangle { width: result-header.width * 28%; Text { text: row.test-time; font-size: 10px; font-family: "Consolas"; color: Theme.text-muted; vertical-alignment: center; horizontal-alignment: center; } }
                                }
                            }
                        }
                    }

                    // L 记录 - 红色标签
                    Rectangle {
                        height: 22px;
                        background: Theme.tag-l.transparentize(92%);
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.tag-l.transparentize(80%);
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 6px;
                            TagBadge { label: "L"; tag-color: Theme.tag-l; }
                            Text { text: "结束: " + msg.l-terminator; font-size: 10px; color: Theme.tag-l; font-weight: 600; vertical-alignment: center; }
                        }
                    }
                }
            }
        }

        // 底部工具栏
        Rectangle {
            height: 32px;
            background: Theme.bg-header;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                alignment: end;
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: "导出 PDF";
                    enabled: root.messages.length > 0;
                    clicked => { root.export-clicked(); }
                }
                Button { text: "清空结果"; clicked => { root.clear-results(); } }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════
// 子组件：双向模式面板
// ═══════════════════════════════════════════════════════════════

component BidirectionalPanel inherits Rectangle {
    in property <bool> is-bidirectional: false;
    in property <bool> is-connected: false;
    in-out property <bool> auto-reply: true;

    callback send-reply();

    visible: root.is-bidirectional;
    border-radius: 6px;
    background: Theme.bg-secondary;
    border-width: 1px;
    border-color: Theme.tag-q.transparentize(70%);

    VerticalLayout {
        PanelHeader {
            title: "双向模式 - 应答设置";
            icon: "";
            accent: Theme.tag-q;
        }

        HorizontalLayout {
            padding: 10px;
            spacing: 12px;
            alignment: center;

            Text { text: "收到仪器查询后"; color: Theme.text-label; font-size: 11px; vertical-alignment: center; }
            Switch { checked <=> root.auto-reply; text: root.auto-reply ? "自动应答" : "手动应答"; }
            Button { text: "发送应答"; enabled: root.is-connected && !root.auto-reply; clicked => { root.send-reply(); } }
            Rectangle { horizontal-stretch: 1; }
            Text { text: "自动模式下收到 Q 记录自动回复结果，手动模式需点击发送"; color: Theme.text-muted; font-size: 10px; vertical-alignment: center; }
        }
    }
}

// ═══════════════════════════════════════════════════════════════
// 子组件：状态栏
// ═══════════════════════════════════════════════════════════════

component StatusBar inherits Rectangle {
    in property <int> msg-count: 0;
    in property <int> result-count: 0;
    in property <string> run-time: "00:00:00";
    in property <string> status-text: "就绪";

    height: 28px;
    background: Theme.bg-header;
    border-width: 1px;
    border-color: Theme.border-default;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 20px;

        HorizontalLayout {
            spacing: 4px;
            Text { text: "消息"; font-size: 10px; color: Theme.text-muted; vertical-alignment: center; }
            Text { text: root.msg-count; font-size: 11px; font-weight: 700; color: Theme.accent-blue; vertical-alignment: center; font-family: "Consolas"; }
        }
        HorizontalLayout {
            spacing: 4px;
            Text { text: "结果"; font-size: 10px; color: Theme.text-muted; vertical-alignment: center; }
            Text { text: root.result-count; font-size: 11px; font-weight: 700; color: Theme.accent-green; vertical-alignment: center; font-family: "Consolas"; }
        }
        HorizontalLayout {
            spacing: 4px;
            Text { text: "运行"; font-size: 10px; color: Theme.text-muted; vertical-alignment: center; }
            Text { text: root.run-time; font-size: 11px; color: Theme.text-secondary; vertical-alignment: center; font-family: "Consolas"; }
        }

        Rectangle { horizontal-stretch: 1; }

        Text { text: root.status-text; font-size: 11px; color: Theme.text-secondary; vertical-alignment: center; }
    }
}

// ═══════════════════════════════════════════════════════════════
// 主窗口
// ═══════════════════════════════════════════════════════════════

export component LisMainWindow inherits Window {
    title: "LIS 模拟器 v1.5.0";
    icon: @image-url("../assets/icon_512.png");
    min-width: 960px;
    min-height: 720px;
    preferred-width: 1100px;
    preferred-height: 850px;
    background: Theme.bg-primary;

    in property <[string]> port-list: [];
    in property <bool> is-connected: false;
    in property <[LogEntry]> log-entries: [];
    in property <[ParsedMessage]> messages: [];
    in property <[[ResultRow]]> result-rows: [];
    in property <int> msg-count: 0;
    in property <int> result-count: 0;
    in property <string> run-time: "00:00:00";
    in property <string> status-text: "就绪";
    in-out property <bool> decode-utf8: false;

    callback refresh-ports();
    callback connect-clicked(string, int, int, int, int, int, bool);
    callback disconnect-clicked();
    callback clear-log();
    callback export-log();
    callback clear-results();
    callback send-reply();
    callback export-clicked();

    VerticalLayout {
        spacing: 6px;
        padding: 8px;

        // 顶部：串口配置
        SerialConfigPanel {
            port-list: root.port-list;
            is-connected: root.is-connected;
            refresh-ports() => { root.refresh-ports(); }
            connect-clicked() => {
                root.connect-clicked(
                    self.port-list[self.selected-port-idx],
                    self.selected-baud-idx,
                    self.selected-databits-idx,
                    self.selected-parity-idx,
                    self.selected-stopbits-idx,
                    self.selected-flowctrl-idx,
                    self.is-bidirectional
                );
            }
            disconnect-clicked() => { root.disconnect-clicked(); }
        }

        // 中间：日志 + 结果 左右分栏
        HorizontalLayout {
            spacing: 6px;
            vertical-stretch: 1;

            // 左：原始日志
            RawLogPanel {
                horizontal-stretch: 2;
                log-entries: root.log-entries;
                decode-utf8 <=> root.decode-utf8;
                clear-log() => { root.clear-log(); }
                export-log() => { root.export-log(); }
            }

            // 右：解析结果
            ParsedResultPanel {
                horizontal-stretch: 3;
                messages: root.messages;
                result-rows: root.result-rows;
                clear-results() => { root.clear-results(); }
                export-clicked() => { root.export-clicked(); }
            }
        }

        // 底部：双向模式
        BidirectionalPanel {
            is-bidirectional: true;
            is-connected: root.is-connected;
            send-reply() => { root.send-reply(); }
        }

        // 状态栏
        StatusBar {
            msg-count: root.msg-count;
            result-count: root.result-count;
            run-time: root.run-time;
            status-text: root.status-text;
        }
    }
}
